function parse(key,fallback){try{return JSON.parse(localStorage.getItem(key))??fallback}catch{return fallback}}
function normalize(s){return (s||"").toString().toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"").trim()}
function mergeRecipes(existing){
  const map=new Map();
  DEFAULT_RECIPES.forEach(r=>map.set(r.id,{...r}));
  existing.forEach(r=>{
    const match=[...map.values()].find(x=>x.id===r.id||normalize(x.name||x.n)===normalize(r.name||r.n));
    const normalized={...r,name:r.name||r.n,category:r.category||r.c,kcal:Number(r.kcal)||parseInt(r.k)||0,protein:Number(r.protein)||parseInt(r.p)||0,ingredients:r.ingredients||r.i||[],steps:r.steps||r.s||"",image:r.image||r.img||match?.image||null,time:r.time||20,servings:r.servings||1,satiety:r.satiety||85,desc:r.desc||r.s||""};
    if(match) map.set(match.id,{...match,...normalized,id:match.id});
    else map.set(normalized.id||"custom_"+Date.now()+"_"+Math.random(),normalized);
  });
  return [...map.values()];
}
function loadOldRecipes(){
  const keys=["pt7_recipes","pt6_recipes","pt51_recipes","pt5_recipes","pt4_recipes","pt3_recipes","pt_recipes_v2","pt_recipes"];
  let all=[];
  keys.forEach(k=>{const a=parse(k,[]);if(Array.isArray(a))all.push(...a)});
  return all;
}
let recipes=mergeRecipes(loadOldRecipes());
let shop=parse(KEYS.shop,["zemiaky","tvaroh","kefír","kuracie prsia","lusky","kyslá kapusta","bataty"]);
let plate=parse(KEYS.plate,[]);
let history=parse(KEYS.history,[]);
let planner=parse(KEYS.planner,{});
let pantry=parse(KEYS.pantry,[]);
let shopDone=parse(KEYS.shopDone,[]);
let diary=parse(KEYS.diary,[]);
let diaryTarget=parse(KEYS.diaryTarget,2000);
let activeCategory="Všetko";

function save(){
  localStorage.setItem(KEYS.recipes,JSON.stringify(recipes));
  localStorage.setItem(KEYS.shop,JSON.stringify(shop));
  localStorage.setItem(KEYS.plate,JSON.stringify(plate));
  localStorage.setItem(KEYS.history,JSON.stringify(history));
  localStorage.setItem(KEYS.planner,JSON.stringify(planner));
  localStorage.setItem(KEYS.pantry,JSON.stringify(pantry));
  localStorage.setItem(KEYS.shopDone,JSON.stringify(shopDone));
  localStorage.setItem(KEYS.diary,JSON.stringify(diary));
  localStorage.setItem(KEYS.diaryTarget,JSON.stringify(diaryTarget));
}
function foodTerms(f){return [f.name,...(f.aliases||[])].map(normalize)}
function findFood(name){
  const x=normalize(name); if(!x)return null;
  return FOOD_DB.find(f=>foodTerms(f).some(a=>a===x))
    || FOOD_DB.find(f=>foodTerms(f).some(a=>a.startsWith(x)||x.startsWith(a)))
    || null;
}
function toast(msg){toastEl.textContent=msg;toastEl.classList.add("show");setTimeout(()=>toastEl.classList.remove("show"),1700)}
function recipeEmoji(r){
  const t=normalize(`${r.name} ${(r.ingredients||[]).join(" ")}`);
  if(t.includes("tvaroh")&&t.includes("ovoc"))return "🥣🍓";
  if(t.includes("kurac")&&t.includes("batat"))return "🍗🍠";
  if(t.includes("kurac")&&t.includes("fazul"))return "🍗🥔";
  if(t.includes("kurac"))return "🍗🥔";
  if(t.includes("dip"))return "🥣🧄";
  if(t.includes("vajc")&&t.includes("zemiak"))return "🍳🥔";
  if(t.includes("tekvic"))return "🎃🥣";
  if(t.includes("kapust")&&t.includes("nakyp"))return "🥬🥔";
  if(t.includes("kapust")&&t.includes("pekac"))return "🥬🧀";
  if(t.includes("kolac")||t.includes("cheesecake"))return "🥔🧀";
  if(t.includes("fazul")||t.includes("lusk"))return "🫛🌿";
  if(t.includes("zemiak")&&t.includes("tvaroh"))return "🥔🥣";
  if(t.includes("panvic"))return "🍳🥔";
  if(t.includes("noc"))return "🌙🥣";
  if(t.includes("ranaj"))return "🥣🍎";
  if(t.includes("obed"))return "🍽️🥗";
  return "🍽️🥗";
}
function xmlSafe(v){return String(v||"").replace(/[&<>\"']/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&apos;"}[c]))}
function autoRecipeImage(r){
  const palettes=[['#e7efe4','#b8cfad'],['#fff0d7','#e5bd82'],['#f3e4df','#d5aaa0'],['#e1edf0','#9fc1c8'],['#eee7f3','#bda9ca']];
  let hash=0;for(const c of String(r.id||r.name||''))hash=(hash*31+c.charCodeAt(0))>>>0;
  const [a,b]=palettes[hash%palettes.length],name=xmlSafe(r.name),cat=xmlSafe(r.category),emoji=recipeEmoji(r);
  const svg=`<svg xmlns="http://www.w3.org/2000/svg" width="800" height="480" viewBox="0 0 800 480"><defs><linearGradient id="g" x1="0" y1="0" x2="1" y2="1"><stop stop-color="${a}"/><stop offset="1" stop-color="${b}"/></linearGradient><filter id="s"><feDropShadow dx="0" dy="12" stdDeviation="14" flood-opacity=".18"/></filter></defs><rect width="800" height="480" rx="42" fill="url(#g)"/><circle cx="400" cy="215" r="145" fill="#fff" fill-opacity=".76" filter="url(#s)"/><text x="400" y="260" text-anchor="middle" font-size="112" font-family="Apple Color Emoji,Segoe UI Emoji,Noto Color Emoji,sans-serif">${emoji}</text><rect x="235" y="370" width="330" height="48" rx="24" fill="#fff" fill-opacity=".82"/><text x="400" y="401" text-anchor="middle" font-size="21" font-weight="700" fill="#35523c" font-family="Arial,sans-serif">${name}</text><text x="400" y="448" text-anchor="middle" font-size="17" fill="#4f6754" font-family="Arial,sans-serif">${cat}</text></svg>`;
  return `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(svg)}`;
}
function imgOrMark(r){const src=r.image||autoRecipeImage(r);return `<img src="${src}" alt="${xmlSafe(r.name)}" loading="lazy">`}
function showScreen(id,btn){
  document.querySelectorAll(".screen").forEach(s=>s.classList.remove("active"));
  document.getElementById(id).classList.add("active");
  document.querySelectorAll(".nav button").forEach(b=>b.classList.remove("active"));
  if(btn)btn.classList.add("active");
  renderAll();
}
function openSpecial(id){showScreen(id,null)}
function categories(){return ["Všetko",...new Set(recipes.map(r=>r.category))]}
function recipeCard(r){
  return `<article class="card"><div class="recipe-photo"><span class="badge">${r.category}</span>${imgOrMark(r)}</div>
  <div class="card-body"><h3>${r.name}</h3><p class="muted">${r.desc}</p>
  <div class="pills"><span class="pill warm">${r.kcal} kcal</span><span class="pill">${r.protein} g bielkovín</span><span class="pill">${r.time} min</span></div>
  <div class="actions"><button class="btn" onclick="openRecipe('${r.id}')">Otvoriť</button><button class="btn secondary" onclick="toggleFav('${r.id}')">${r.fav?"Uložené":"Uložiť"}</button></div></div></article>`;
}
function renderHome(){
  recipeCount.textContent=recipes.length; favCount.textContent=recipes.filter(r=>r.fav).length; historyCount.textContent=history.length;
  const fav=recipes.filter(r=>r.fav).slice(0,6);
  favList.innerHTML=fav.length?fav.map(recipeCard).join(""):`<div class="empty">Zatiaľ žiadne obľúbené recepty.</div>`;
}
function renderRecipes(){
  tabs.innerHTML=categories().map(c=>`<button class="tab ${activeCategory===c?"active":""}" onclick="activeCategory='${c}';renderRecipes()">${c}</button>`).join("");
  const q=normalize(recipeSearch.value);
  const list=recipes.filter(r=>(activeCategory==="Všetko"||r.category===activeCategory)&&normalize(JSON.stringify(r)).includes(q));
  document.getElementById('recipesGrid').innerHTML=list.length?list.map(recipeCard).join(""):`<div class="empty">Nič som nenašiel.</div>`;
}
function openRecipe(id){
  const r=recipes.find(x=>x.id===id); if(!r)return;
  detail.innerHTML=`<button class="close" onclick="closeDetail()">×</button><div class="card">
  <div class="detail-hero">${imgOrMark(r)}</div><div class="card-body"><h2>${r.name}</h2><p class="muted">${r.desc}</p>
  <div class="pills"><span class="pill warm">${r.kcal} kcal</span><span class="pill">${r.protein} g bielkovín</span><span class="pill">${r.time} min</span><span class="pill">${r.servings} porcia</span><span class="pill">Sýtosť ${r.satiety}/100</span></div>
  <h3>Suroviny</h3><ul>${r.ingredients.map(x=>`<li>${x}</li>`).join("")}</ul><h3>Postup</h3><p>${r.steps}</p>
  <button class="btn full" onclick="addRecipeToPlate('${r.id}')">Pridať do Môjho taniera</button>
  <button class="btn secondary full" onclick="addRecipeToShop('${r.id}')">Pridať suroviny do nákupu</button>
  <button class="btn secondary full" onclick="toggleFav('${r.id}');openRecipe('${r.id}')">${r.fav?"Odobrať z obľúbených":"Pridať medzi obľúbené"}</button>
  <details class="edit-panel"><summary>Upraviť recept</summary><div style="margin-top:12px">
  <input class="input" id="editName" value="${r.name.replaceAll('"',"&quot;")}"><input class="input" id="editPhoto" type="file" accept="image/*">
  <div class="inline-2"><input class="input" id="editKcal" type="number" value="${r.kcal}"><input class="input" id="editProtein" type="number" value="${r.protein}"></div>
  <div class="inline-2"><input class="input" id="editTime" type="number" value="${r.time}"><input class="input" id="editServings" type="number" value="${r.servings}"></div>
  <textarea id="editIngredients">${r.ingredients.join("\n")}</textarea><textarea id="editSteps">${r.steps}</textarea>
  <button class="btn full" onclick="saveRecipeEdit('${r.id}')">Uložiť zmeny</button><button class="btn danger full" onclick="removeRecipePhoto('${r.id}')">Odstrániť fotku</button>
  ${r.id.startsWith("custom_")?`<button class="btn danger full" onclick="deleteRecipe('${r.id}')">Vymazať recept</button>`:""}</div></details>
  </div></div>`;
  detail.classList.add("show");
}
function closeDetail(){detail.classList.remove("show")}
function toggleFav(id){recipes=recipes.map(r=>r.id===id?{...r,fav:!r.fav}:r);save();renderAll()}
function randomRecipe(){const r=recipes[Math.floor(Math.random()*recipes.length)];todayPick.innerHTML=recipeCard(r)}
function readImage(file){return new Promise(res=>{if(!file)return res(null);const fr=new FileReader();fr.onload=()=>res(fr.result);fr.readAsDataURL(file)})}
async function addRecipe(){
  const image=await readImage(newRecipePhoto.files[0]);
  recipes.push({id:"custom_"+Date.now(),name:newRecipeName.value||"Nový recept",category:newRecipeCategory.value,kcal:+newRecipeKcal.value||0,protein:+newRecipeProtein.value||0,time:+newRecipeTime.value||20,servings:+newRecipeServings.value||1,satiety:+newRecipeSatiety.value||80,desc:newRecipeDesc.value||"",fav:false,image,ingredients:newRecipeIngredients.value.split("\n").filter(Boolean),steps:newRecipeSteps.value||"",plate:[]});
  save(); document.querySelectorAll("#addScreen input,#addScreen textarea").forEach(x=>{if(x.type!=="number")x.value=""}); toast("Recept uložený"); renderAll();
}
async function saveRecipeEdit(id){
  const img=await readImage(editPhoto.files[0]);
  recipes=recipes.map(r=>r.id===id?{...r,name:editName.value,kcal:+editKcal.value||r.kcal,protein:+editProtein.value||r.protein,time:+editTime.value||r.time,servings:+editServings.value||r.servings,ingredients:editIngredients.value.split("\n").filter(Boolean),steps:editSteps.value,image:img||r.image}:r);
  save();renderAll();openRecipe(id);toast("Recept upravený");
}
function removeRecipePhoto(id){recipes=recipes.map(r=>r.id===id?{...r,image:null}:r);save();renderAll();openRecipe(id)}
function deleteRecipe(id){if(!confirm("Vymazať tento recept?"))return;recipes=recipes.filter(r=>r.id!==id);save();closeDetail();renderAll()}
function addRecipeToPlate(id){
  const r=recipes.find(x=>x.id===id); if(!r)return;
  (r.plate||[]).forEach(([name,g])=>addFoodToPlate(name,g,false));
  save();toast("Recept pridaný do taniera");
}
function addRecipeToShop(id){const r=recipes.find(x=>x.id===id);if(!r)return;r.ingredients.forEach(x=>shop.push(x));save();toast("Suroviny pridané do nákupu")}
function initFoodSuggestions(){foodSuggestions.innerHTML=FOOD_DB.flatMap(f=>[f.name,...f.aliases]).map(n=>`<option value="${n}"></option>`).join("")}
function autofillFood(){
  const f=findFood(foodName.value);
  if(f){foodKcal.value=f.k;foodProtein.value=f.p;foodCarbs.value=f.c;foodFat.value=f.f;foodFiber.value=f.fiber;foodHint.textContent=`Doplnené z databázy: ${f.k} kcal / 100 g.`}
  else foodHint.textContent="Potravinu nepoznám. Hodnoty môžeš doplniť ručne.";
}
function addFoodToPlate(name,grams=0,notify=true){
  const f=findFood(name); if(!f)return;
  const found=plate.find(x=>normalize(x.name)===normalize(f.name));
  if(found)found.grams+=grams;else plate.push({name:f.name,k:f.k,p:f.p,c:f.c,f:f.f,fiber:f.fiber,grams});
  save();renderPlate();if(notify)toast("Potravina pridaná");
}
function addCustomFood(){
  const name=foodName.value.trim(); const known=findFood(name);
  const data=known||{name,k:+foodKcal.value,p:+foodProtein.value,c:+foodCarbs.value,f:+foodFat.value,fiber:+foodFiber.value};
  const grams=Math.max(0,+foodGrams.value||0);
  if(!data.name||!data.k){toast("Doplň názov a kalórie");return}
  const found=plate.find(x=>normalize(x.name)===normalize(data.name));
  if(found)found.grams+=grams;else plate.push({...data,grams});
  [foodName,foodKcal,foodProtein,foodCarbs,foodFat,foodFiber].forEach(x=>x.value="");foodGrams.value=100;save();renderPlate();toast(`Potravina pridaná · ${grams} g`);
}
function renderPlate(){
  plateRows.innerHTML=plate.length?plate.map((x,i)=>`<div class="plate-item"><div><b>${x.name}</b><div class="muted">${x.k} kcal / 100 g</div></div><div class="counter"><button onclick="changeGrams(${i},-10)">−</button><input class="grams-input" value="${x.grams}" onchange="setGrams(${i},this.value)"><button onclick="changeGrams(${i},10)">+</button></div><button class="icon-btn" onclick="removePlateFood(${i})" title="Odstrániť">×</button></div>`).join(""):`<div class="empty">Pridaj prvú potravinu.</div>`;
  let total={k:0,p:0,c:0,f:0,fiber:0,g:0};plate.forEach(x=>{const m=x.grams/100;total.k+=x.k*m;total.p+=x.p*m;total.c+=x.c*m;total.f+=x.f*m;total.fiber+=(x.fiber||0)*m;total.g+=x.grams});
  const sat=Math.min(100,Math.round(total.g/8+total.p*1.15+total.fiber*1.5));
  plateTotal.innerHTML=`${Math.round(total.k)} kcal<br>${Math.round(total.p)} g bielkovín · ${Math.round(total.c)} g sacharidov · ${Math.round(total.f)} g tukov · ${Math.round(total.fiber)} g vlákniny`;
  plateSatiety.innerHTML=`Index sýtosti: <b>${sat}/100</b>${sat>=85?" · Plný tanier certifikát":""}`;
}
function changeGrams(i,d){plate[i].grams=Math.max(0,(+plate[i].grams||0)+d);save();renderPlate()}
function setGrams(i,v){plate[i].grams=Math.max(0,+String(v).replace(",",".")||0);save();renderPlate()}
function removePlateFood(i){plate.splice(i,1);save();renderPlate();toast("Potravina odstránená")}
function clearPlate(){if(!plate.length)return;plate=[];save();renderPlate()}
function savePlateHistory(){
  if(!plate.length){toast("Tanier je prázdny");return}
  history.unshift({id:Date.now(),date:new Date().toLocaleString("sk-SK"),items:structuredClone(plate)});
  save();renderHistory();toast("Tanier uložený");
}
function renderHistory(){
  historyList.innerHTML=history.length?history.map((h,i)=>`<div class="card history-item"><h3>${h.date}</h3><div class="muted">${h.items.map(x=>`${x.name} ${x.grams} g`).join(" · ")}</div><div class="actions"><button class="btn secondary" onclick="restorePlate(${i})">Načítať</button><button class="btn danger" onclick="deleteHistory(${i})">Vymazať</button></div></div>`).join(""):`<div class="empty">Zatiaľ žiadne uložené taniere.</div>`;
}
function restorePlate(i){plate=structuredClone(history[i].items);save();openSpecial("plateScreen");renderPlate()}
function deleteHistory(i){history.splice(i,1);save();renderHistory()}
function addShop(){const v=shopInput.value.trim();if(!v)return;shop.push(v);shopDone.push(false);shopInput.value="";save();renderShop()}
function toggleShopDone(i,checked){shopDone[i]=checked;save();renderShop()}
function removeShopItem(i){shop.splice(i,1);shopDone.splice(i,1);save();renderShop()}
function clearDoneShop(){
  const kept=shop.map((x,i)=>({x,done:!!shopDone[i]})).filter(v=>!v.done);shop=kept.map(v=>v.x);shopDone=kept.map(()=>false);save();renderShop();toast("Kúpené položky odstránené");
}
function clearShop(){if(!shop.length||!confirm("Vymazať celý nákupný zoznam?"))return;shop=[];shopDone=[];save();renderShop()}
function localDateISO(d=new Date()){const x=new Date(d);x.setMinutes(x.getMinutes()-x.getTimezoneOffset());return x.toISOString().slice(0,10)}
function openDiaryToday(){diaryDate.value=localDateISO();openSpecial("diaryScreen");renderDiary()}
function changeDiaryDay(delta){const d=new Date((diaryDate.value||localDateISO())+"T12:00:00");d.setDate(d.getDate()+delta);diaryDate.value=localDateISO(d);renderDiary()}
function autofillDiaryFood(){const f=findFood(diaryFoodName.value);if(!f)return;diaryKcal100.value=f.k;diaryProtein100.value=f.p;diaryCarbs100.value=f.c;diaryFat100.value=f.f}
function diaryMealForCategory(category){const c=normalize(category);if(c.includes("ranaj"))return "Raňajky";if(c.includes("obed"))return "Obed";if(c.includes("vecer"))return "Večera";if(c.includes("noc"))return "Iné";return "Iné"}
function syncDiaryMealFromRecipe(){const r=recipes.find(x=>x.id===diaryRecipe.value);if(r)diaryRecipeMeal.value=diaryMealForCategory(r.category)}
function renderDiaryRecipeOptions(){
  if(!window.diaryRecipe)return;
  const current=diaryRecipe.value;
  diaryRecipe.innerHTML=`<option value="">— vyber recept —</option>${recipes.slice().sort((a,b)=>a.name.localeCompare(b.name,"sk")).map(r=>`<option value="${r.id}">${r.name} · ${r.kcal} kcal</option>`).join("")}`;
  if(recipes.some(r=>r.id===current))diaryRecipe.value=current;
}
function addRecipeToDiary(){
  const r=recipes.find(x=>x.id===diaryRecipe.value);if(!r){toast("Vyber recept");return}
  const meal=diaryRecipeMeal.value,date=diaryDate.value||localDateISO(),groupId="recipe_"+Date.now();
  const parts=(r.plate||[]).map((x,i)=>{const f=findFood(x[0]);return f?{id:Date.now()+i,date,meal,name:x[0],grams:+x[1]||0,kcal100:f.k,protein100:f.p,carbs100:f.c,fat100:f.f,recipeName:r.name,groupId}:null}).filter(Boolean);
  if(parts.length){diary.push(...parts)}else{diary.push({id:Date.now(),date,meal,name:r.name,grams:1,kcal100:(+r.kcal||0)*100,protein100:(+r.protein||0)*100,carbs100:0,fat100:0,recipeName:r.name,groupId})}
  save();renderDiary();toast(`${r.name} pridaný do denníka`)
}
function addDiaryEntry(){
  const name=diaryFoodName.value.trim(), grams=Math.max(0,+diaryGrams.value||0), kcal100=Math.max(0,+diaryKcal100.value||0);
  if(!name||!grams||!kcal100){toast("Doplň jedlo, gramy a kalórie");return}
  diary.push({id:Date.now(),date:diaryDate.value||localDateISO(),meal:diaryMeal.value,name,grams,kcal100,protein100:+diaryProtein100.value||0,carbs100:+diaryCarbs100.value||0,fat100:+diaryFat100.value||0});
  [diaryFoodName,diaryKcal100,diaryProtein100,diaryCarbs100,diaryFat100].forEach(x=>x.value="");diaryGrams.value=100;save();renderDiary();toast("Zapísané do denníka")
}
function deleteDiaryEntry(id){diary=diary.filter(x=>x.id!==id);save();renderDiary()}
function saveDiaryTarget(){diaryTarget=Math.max(500,+diaryTargetInput.value||2000);save();renderDiary();toast("Denný cieľ uložený")}
function addPlateToDiary(){
  if(!plate.length){toast("Tanier je prázdny");return}
  const meal=prompt("Kam ho zapísať? Raňajky, Obed, Večera alebo Iné","Obed")||"Iné";
  const date=localDateISO();plate.forEach((x,n)=>diary.push({id:Date.now()+n,date,meal,name:x.name,grams:+x.grams||0,kcal100:+x.k||0,protein100:+x.p||0,carbs100:+x.c||0,fat100:+x.f||0}));save();toast("Tanier zapísaný do dnešného denníka")
}
function renderDiary(){
  if(!diaryDate.value)diaryDate.value=localDateISO();diaryTargetInput.value=diaryTarget;renderDiaryRecipeOptions();
  const items=diary.filter(x=>x.date===diaryDate.value), meals=["Raňajky","Desiata","Obed","Olovrant","Večera","Iné"];
  let totals={k:0,p:0,c:0,f:0};items.forEach(x=>{const m=x.grams/100;totals.k+=x.kcal100*m;totals.p+=(x.protein100||0)*m;totals.c+=(x.carbs100||0)*m;totals.f+=(x.fat100||0)*m});
  const kcal=Math.round(totals.k), remaining=Math.round(diaryTarget-kcal), percent=Math.min(100,Math.round(kcal/diaryTarget*100));
  diaryCalories.textContent=`${kcal} kcal`;diaryRemaining.textContent=remaining>=0?`Zostáva ${remaining} kcal`:`Nad cieľom o ${Math.abs(remaining)} kcal`;diaryProgress.style.width=percent+"%";diaryMacros.textContent=`${Math.round(totals.p)} g bielkovín · ${Math.round(totals.c)} g sacharidov · ${Math.round(totals.f)} g tukov`;
  diaryList.innerHTML=items.length?meals.map(meal=>{const group=items.filter(x=>x.meal===meal);if(!group.length)return"";const sum=Math.round(group.reduce((a,x)=>a+x.kcal100*x.grams/100,0));return `<div class="meal-group"><div class="meal-title"><h3>${meal}</h3><span class="muted">${sum} kcal</span></div><div class="grid">${group.map(x=>`<div class="card diary-entry"><div><b>${x.name}</b><span class="muted">${x.grams} g · ${x.kcal100} kcal / 100 g</span></div><span class="kcal">${Math.round(x.kcal100*x.grams/100)} kcal</span><button class="icon-btn" onclick="deleteDiaryEntry(${x.id})">×</button></div>`).join("")}</div></div>`}).join(""):`<div class="empty">V tento deň zatiaľ nič nie je zapísané.</div>`
}
function renderShop(){
  while(shopDone.length<shop.length)shopDone.push(false);if(shopDone.length>shop.length)shopDone=shopDone.slice(0,shop.length);
  const doneCount=shopDone.filter(Boolean).length;
  shopProgress.textContent=`${doneCount}/${shop.length} kúpené`;
  shoppingList.innerHTML=shop.length?shop.map((x,i)=>`<div class="card shop-item ${shopDone[i]?"done":""}"><input type="checkbox" ${shopDone[i]?"checked":""} onchange="toggleShopDone(${i},this.checked)"><span class="shop-name">${x}</span><button class="icon-btn" style="margin-left:auto" onclick="removeShopItem(${i})">×</button></div>`).join(""):`<div class="empty">Nákupný zoznam je prázdny.</div>`;
}
function renderPlanner(){
  const days=["Pondelok","Utorok","Streda","Štvrtok","Piatok","Sobota","Nedeľa"];
  plannerRows.innerHTML=days.map(d=>`<div class="day-row"><label>${d}</label><select onchange="planner['${d}']=this.value;save()"><option value="">— vyber recept —</option>${recipes.map(r=>`<option value="${r.id}" ${planner[d]===r.id?"selected":""}>${r.name}</option>`).join("")}</select></div>`).join("");
}
function randomizePlanner(){
  const days=["Pondelok","Utorok","Streda","Štvrtok","Piatok","Sobota","Nedeľa"];
  if(!recipes.length)return;
  days.forEach(d=>planner[d]=recipes[Math.floor(Math.random()*recipes.length)].id);
  save();renderPlanner();toast("Týždeň náhodne vyplnený");
}
function clearPlanner(){
  if(!Object.values(planner).some(Boolean))return;
  planner={};save();renderPlanner();toast("Plán vyčistený");
}
function addPlannerToShop(){
  Object.values(planner).filter(Boolean).forEach(id=>{const r=recipes.find(x=>x.id===id);if(r)r.ingredients.forEach(i=>shop.push(i))});
  save();renderShop();toast("Týždeň pridaný do nákupu");
}
function renderChef(){
  chefResults.innerHTML="";
  pantryInput.value=pantry.join(", ");
}
function chefSuggest(){
  const ingredients=pantryInput.value.split(",").map(normalize).filter(Boolean);
  pantry=ingredients; const maxK=+chefMaxKcal.value||9999, minP=+chefMinProtein.value||0;
  const scored=recipes.map(r=>{const text=normalize(JSON.stringify(r));const score=ingredients.reduce((s,x)=>s+(text.includes(x)?1:0),0);return{r,score}})
    .filter(x=>x.r.kcal<=maxK&&x.r.protein>=minP&&(ingredients.length===0||x.score>0)).sort((a,b)=>b.score-a.score||b.r.satiety-a.r.satiety).slice(0,6);
  chefResults.innerHTML=scored.length?scored.map(x=>recipeCard(x.r)).join(""):`<div class="empty">Nenašiel som vhodný recept. Skús menej podmienok.</div>`;save();
}
function exportData(){
  const blob=new Blob([JSON.stringify({version:VERSION,recipes,shop,shopDone,plate,history,planner,pantry,diary,diaryTarget},null,2)],{type:"application/json"});
  const a=document.createElement("a");a.href=URL.createObjectURL(blob);a.download="plny-tanier-zaloha.json";a.click();URL.revokeObjectURL(a.href);
}
async function importData(){
  const file=backupInput.files[0];if(!file)return;try{const d=JSON.parse(await file.text());recipes=mergeRecipes(d.recipes||[]);shop=d.shop||shop;plate=d.plate||plate;history=d.history||history;planner=d.planner||planner;pantry=d.pantry||pantry;shopDone=d.shopDone||shop.map(()=>false);diary=d.diary||diary;diaryTarget=d.diaryTarget||diaryTarget;save();renderAll();toast("Záloha obnovená")}catch{toast("Neplatný súbor")}
}
function renderFoodCards(){foodCards.innerHTML=FOOD_DB.slice(0,16).map(f=>`<div class="card food-card"><b>${f.name}</b><div class="muted">${f.k} kcal · ${f.p} g bielkovín · ${f.fiber} g vlákniny</div></div>`).join("")}
function renderAll(){renderHome();renderRecipes();renderPlate();renderHistory();renderShop();renderPlanner();renderChef();renderFoodCards();renderDiary();save()}
window.addEventListener("load",()=>{initFoodSuggestions();renderAll();if("serviceWorker"in navigator)navigator.serviceWorker.register("./sw.js").then(r=>r.update())});
</script></body></html>